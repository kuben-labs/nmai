# LLM Provider (via model-providers)
# Options: ollama, azure, grok, groq, google, vertex-gemini, vertex-claude
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash

# Embedding Provider (via model-providers)
# Options: ollama, azure, google
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=3072

# Google / Vertex AI credentials
GCP_API_KEY=your-google-api-key
# GCP_PROJECT=your-gcp-project          # required for vertex-gemini, vertex-claude
# GCP_LOCATION=us-central1              # default for vertex-gemini (us-east5 for vertex-claude)

# Ollama (if using ollama provider)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# RAG tool filtering
TOP_K=200
